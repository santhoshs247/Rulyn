# Server
PORT=3000
NODE_ENV=development

# MySQL Database URL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/rulyn_db"


# Clerk - for verifying student tokens (get from https://clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT - for teacher authentication (any long random string, min 32 chars)
JWT_SECRET=rulyn_super_secret_jwt_key_change_in_production_32chars
JWT_EXPIRES_IN=7d

# CORS - allow requests from the frontend dev server
FRONTEND_URL=http://localhost:5173
